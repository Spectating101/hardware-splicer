(kicad_pcb (version 20211014) (generator "circuit_splicer_mint"))
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (44 "Edge.Cuts" user)
  )
  (setup (pad_to_mask_clearance 0))
  (gr_rect (start 0 0) (end 100.0 70.0) (layer "Edge.Cuts") (width 0.1) (fill none))
  (footprint "MountingHole_NPTH_1" (layer "F.Cu")
    (at 8.0 8.0)
    (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.0 3.0) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole_NPTH_2" (layer "F.Cu")
    (at 92.0 8.0)
    (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.0 3.0) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole_NPTH_3" (layer "F.Cu")
    (at 8.0 62.0)
    (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.0 3.0) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
  (footprint "MountingHole_NPTH_4" (layer "F.Cu")
    (at 92.0 62.0)
    (attr exclude_from_pos_files exclude_from_bom)
    (pad "" np_thru_hole circle (at 0 0) (size 3.0 3.0) (drill 2.2) (layers "*.Cu" "*.Mask"))
  )
)
