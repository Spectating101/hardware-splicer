(kicad_pcb (version 20221018) (generator pcbnew)
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (44 "Edge.Cuts" user)
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "VBUS")
  (net 3 "VIN")
  (net 4 "+3V3")
  (net 5 "SDA")
  (net 6 "SCL")
  (net 7 "ALERT")

  (gr_line (start 0 0) (end 60 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 60 0) (end 60 40) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 60 40) (end 0 40) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 40) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  (footprint "Connector_USB:USB_C_Receptacle_USB2.0" (layer "F.Cu")
    (at 6 20 90)
    (property "Reference" "J1")
    (property "Value" "USB-C")
    (pad "A1" smd (net 1 "GND"))
    (pad "A4" smd (net 2 "VBUS"))
  )

  (footprint "Regulator_Linear:SOT-223-3_TabPin2" (layer "F.Cu")
    (at 18 20 0)
    (property "Reference" "U2")
    (property "Value" "LDO_3V3")
    (pad "1" smd (net 1 "GND"))
    (pad "2" smd (net 4 "+3V3"))
    (pad "3" smd (net 3 "VIN"))
  )

  (footprint "Module:ESP32-WROOM-32" (layer "F.Cu")
    (at 38 20 0)
    (property "Reference" "U1")
    (property "Value" "ESP32")
    (pad "1" smd (net 4 "+3V3"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 5 "SDA"))
    (pad "4" smd (net 6 "SCL"))
  )

  (footprint "Sensor:BME280" (layer "F.Cu")
    (at 50 20 0)
    (property "Reference" "U3")
    (property "Value" "BME280")
    (pad "1" smd (net 4 "+3V3"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 6 "SCL"))
    (pad "4" smd (net 5 "SDA"))
    (pad "5" smd (net 7 "ALERT"))
  )

  (footprint "Resistor_SMD:R_0603_1608Metric" (layer "F.Cu")
    (at 45 30 0)
    (property "Reference" "R1")
    (property "Value" "4K7")
    (pad "1" smd (net 4 "+3V3"))
    (pad "2" smd (net 5 "SDA"))
  )

  (footprint "Resistor_SMD:R_0603_1608Metric" (layer "F.Cu")
    (at 48 30 0)
    (property "Reference" "R2")
    (property "Value" "4K7")
    (pad "1" smd (net 4 "+3V3"))
    (pad "2" smd (net 6 "SCL"))
  )

  (footprint "Capacitor_SMD:C_0603_1608Metric" (layer "F.Cu")
    (at 20 30 0)
    (property "Reference" "C1")
    (property "Value" "10uF")
    (pad "1" smd (net 3 "VIN"))
    (pad "2" smd (net 1 "GND"))
  )

  (footprint "Capacitor_SMD:C_0603_1608Metric" (layer "F.Cu")
    (at 22 30 0)
    (property "Reference" "C2")
    (property "Value" "10uF")
    (pad "1" smd (net 4 "+3V3"))
    (pad "2" smd (net 1 "GND"))
  )

  (segment (start 6 20) (end 14 20) (width 0.2) (layer "F.Cu") (net 2))
  (segment (start 14 20) (end 18 20) (width 0.2) (layer "F.Cu") (net 2))
  (segment (start 18 20) (end 18 24) (width 0.2) (layer "F.Cu") (net 3))
  (segment (start 18 24) (end 38 24) (width 0.2) (layer "F.Cu") (net 4))
  (segment (start 38 24) (end 50 24) (width 0.2) (layer "F.Cu") (net 4))

  (segment (start 6 18) (end 14 18) (width 0.25) (layer "F.Cu") (net 1))
  (segment (start 14 18) (end 38 18) (width 0.25) (layer "F.Cu") (net 1))
  (segment (start 38 18) (end 50 18) (width 0.25) (layer "F.Cu") (net 1))
)
