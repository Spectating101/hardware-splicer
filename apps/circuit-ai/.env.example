# Circuit-AI Environment Variables

# API Configuration
PORT=5000
FLASK_ENV=production
DEBUG=False

# API Key + Quotas (Monetization)
# If CIRCUIT_AI_REQUIRE_API_KEY is true OR CIRCUIT_AI_API_KEYS is set OR the DB contains active keys,
# v2 endpoints require auth via:
#   Authorization: Bearer <API_KEY>
# or:
#   X-API-Key: <API_KEY>
CIRCUIT_AI_REQUIRE_API_KEY=false
# Simple allowlist mode (comma-separated). For production, prefer issuing keys via /api/v2/admin/keys.
CIRCUIT_AI_API_KEYS=
# Admin token enables /api/v2/admin/* endpoints for issuing/revoking keys.
CIRCUIT_AI_ADMIN_TOKEN=change_me_admin_token
# Usage/keys DB (defaults to /tmp/circuit-ai-usage.sqlite)
CIRCUIT_AI_USAGE_DB=
# Default daily quota per key (can be overridden per-key via admin quotas_json, or per-action via env)
CIRCUIT_AI_QUOTA_DEFAULT_PER_DAY=200
CIRCUIT_AI_QUOTA_VALIDATE_KICAD_PER_DAY=
CIRCUIT_AI_QUOTA_MANUFACTURE_BOM_PER_DAY=
CIRCUIT_AI_QUOTA_MANUFACTURE_GERBER_PER_DAY=

# Two-tier convenience issuance:
# POST /api/v2/admin/keys/issue with plan=free|paid.

# LLM API Keys (optional - for enhanced features)
CEREBRAS_API_KEY=your_cerebras_key_here
OPENAI_API_KEY=your_openai_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
LLM_PROVIDER=copilot
LLM_MODEL=gpt-4.1
LLM_API_BASE=
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=
JARVIS_TEXT_PROVIDER=copilot
JARVIS_VISION_PROVIDER=copilot
MISTRAL_API_KEY=

# Paid native vision trial. Keep disabled unless you explicitly select Qwen.
# To run the $5 Qwen-first trial:
#   JARVIS_VISION_PROVIDER=qwen
#   QWEN_API_KEY=<your Model Studio key>
#   VISION_MONTHLY_USD_LIMIT=5
QWEN_DISABLED=true
QWEN_OUT_OF_QUOTA=false
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3.5-122b-a10b
QWEN_MODEL_ROTATION=qwen3.5-122b-a10b,qwen3-max,qwen3.5-plus-2026-02-15
QWEN_VISION_MODEL=qwen3-vl-flash
QWEN_VISION_MODEL_ROTATION=qwen3-vl-flash,qwen3-vl-30b-a3b-thinking,qwen-vl-ocr-2025-11-20
QWEN_LOW_QUOTA_MODELS=qwen-plus,qwen-plus-2025-07-28
QWEN_IMAGE_MAX_PIXELS=
QWEN_VL_HIGH_RESOLUTION_IMAGES=false
QWEN_JSON_MODE_DISABLED=false
VISION_MONTHLY_USD_LIMIT=0
VISION_DAILY_USD_LIMIT=1
VISION_MAX_USD_PER_CALL=0.05
VISION_REQUIRE_CACHE=true
VISION_MAX_CROPS_PER_SCAN=3
VISION_ESCALATE_ONLY_ON_UNCERTAIN=true
VISION_SPEND_LEDGER=

# Local Copilot CLI/OAuth text reasoning.
# Prefer stored GitHub/Copilot auth on the machine; do not commit token values.
COPILOT_MODEL=gpt-4.1
COPILOT_NODE_RUNNER=npx -y node@20
COPILOT_TIMEOUT_SECONDS=90

# Pricing Service (optional)
DIGIKEY_API_KEY=your_digikey_key_here
DIGIKEY_CLIENT_ID=your_digikey_client_id_here

# Database (optional - uses SQLite by default)
DATABASE_URL=sqlite:///circuit_ai.db

# Redis (optional - for caching)
REDIS_URL=redis://localhost:6379

# Monitoring (optional)
SENTRY_DSN=your_sentry_dsn_here

# Rate Limiting
RATE_LIMIT_ENABLED=true
FREE_TIER_LIMIT=10
PRO_TIER_LIMIT=100

# Stripe (for payments - will set up later)
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key
