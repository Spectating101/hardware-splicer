(kicad_pcb (version 20221018) (generator pcbnew)
  (general (thickness 1.6))
  (paper "A4")
  (layers
    (0 "F.Cu" signal)
    (31 "B.Cu" signal)
    (44 "Edge.Cuts" user)
  )

  (net 0 "")
  (net 1 "GND")
  (net 2 "VBAT")
  (net 3 "VBAT_BUS")
  (net 4 "+5V")
  (net 5 "+3V3")
  (net 6 "SCL")
  (net 7 "SDA")
  (net 8 "RX")
  (net 9 "TX")
  (net 10 "M1")
  (net 11 "M2")
  (net 12 "M3")
  (net 13 "M4")

  (gr_line (start 0 0) (end 70 0) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 70 0) (end 70 50) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 70 50) (end 0 50) (layer "Edge.Cuts") (width 0.1))
  (gr_line (start 0 50) (end 0 0) (layer "Edge.Cuts") (width 0.1))

  (footprint "Connector:XT30" (layer "F.Cu")
    (at 8 25 90)
    (property "Reference" "J1")
    (property "Value" "BAT_IN")
    (pad "1" smd (net 2 "VBAT"))
    (pad "2" smd (net 1 "GND"))
  )

  (footprint "Regulator_Switching:BUCK_5V" (layer "F.Cu")
    (at 22 25 0)
    (property "Reference" "U2")
    (property "Value" "BUCK_5V")
    (pad "1" smd (net 3 "VBAT_BUS"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 4 "+5V"))
  )

  (footprint "Regulator_Linear:LDO_3V3" (layer "F.Cu")
    (at 34 25 0)
    (property "Reference" "U3")
    (property "Value" "LDO_3V3")
    (pad "1" smd (net 4 "+5V"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 5 "+3V3"))
  )

  (footprint "Module:MCU_FC" (layer "F.Cu")
    (at 46 25 0)
    (property "Reference" "U1")
    (property "Value" "FC_MCU")
    (pad "1" smd (net 5 "+3V3"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 8 "RX"))
    (pad "4" smd (net 9 "TX"))
    (pad "5" smd (net 6 "SCL"))
    (pad "6" smd (net 7 "SDA"))
  )

  (footprint "Sensor:IMU_MPU6000" (layer "F.Cu")
    (at 56 25 0)
    (property "Reference" "U4")
    (property "Value" "IMU")
    (pad "1" smd (net 5 "+3V3"))
    (pad "2" smd (net 1 "GND"))
    (pad "3" smd (net 6 "SCL"))
    (pad "4" smd (net 7 "SDA"))
  )

  (footprint "Connector:ESC_HEADER_8" (layer "F.Cu")
    (at 62 10 0)
    (property "Reference" "J2")
    (property "Value" "ESC/MOTORS")
    (pad "1" smd (net 1 "GND"))
    (pad "2" smd (net 3 "VBAT_BUS"))
    (pad "3" smd (net 10 "M1"))
    (pad "4" smd (net 11 "M2"))
    (pad "5" smd (net 12 "M3"))
    (pad "6" smd (net 13 "M4"))
    (pad "7" smd (net 8 "RX"))
    (pad "8" smd (net 9 "TX"))
  )

  (segment (start 8 25) (end 16 25) (width 0.25) (layer "F.Cu") (net 2))
  (segment (start 16 25) (end 22 25) (width 0.25) (layer "F.Cu") (net 3))

  (segment (start 22 27) (end 34 27) (width 0.2) (layer "F.Cu") (net 4))
  (segment (start 34 27) (end 46 27) (width 0.2) (layer "F.Cu") (net 5))
  (segment (start 46 27) (end 56 27) (width 0.2) (layer "F.Cu") (net 5))

  (segment (start 8 23) (end 22 23) (width 0.3) (layer "F.Cu") (net 1))
  (segment (start 22 23) (end 62 23) (width 0.3) (layer "F.Cu") (net 1))

  (segment (start 22 25) (end 62 10) (width 0.25) (layer "F.Cu") (net 3))
)

