            "bringup_notes": true
          },
          "board": {
            "layers": 2,
            "dimensions_mm": {"x": 80, "y": 50},
            "stackup": {
              "manufacturer": "JLCPCB standard 2-layer",
              "notes": "1.6 mm FR-4, 1 oz copper, prototype impedance is not controlled."
            },
            "environment": {
              "ambient_c": 25,
              "max_c": 45,
              "notes": "Indoor bench prototype."
