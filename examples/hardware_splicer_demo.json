            "decoupling": {
              "strategy": "USB bulk input, regulator output bulk, and local 100 nF per IC.",
              "confirmed": true,
              "notes": "Servo rail should have separate bulk capacitance at the header."
            },
            "protection": {
              "reverse_polarity": "USB keyed input and JST keyed servo input",
              "fuse_or_ptc": "USB source current limit; add PTC before release",
              "tvs": "USB data ESD recommended",
              "inrush_limit": "not required for starter bench prototype",
              "notes": "Servo rail intentionally separated from logic regulator."
            }
          },
          "manufacturing": {
            "fab": {
              "name": "JLCPCB",
              "url": "https://jlcpcb.com",
              "notes": "Prototype constraints."
            },
            "assembly": {
              "name": "manual bring-up",
              "notes": "Hand assembly is acceptable for the canonical demo."
            },
            "dnp_policy": "explicit",
            "preferred_part_source": "LCSC/DigiKey"
          },
          "risk_and_validation": {
            "what_good_looks_like": "Board enumerates over USB, firmware uploads through CP2102, 3V3 stays in tolerance, and both servo PWM outputs move the pan-tilt mechanism without MCU reset.",
            "test_plan": "Check USB VBUS, 3V3 rail, USB serial upload, pan PWM, tilt PWM, servo rail isolation, and motion under the configured payload before closing the enclosure.",
            "known_risks": [
              "Servo rail needs separate bulk capacitance and a current limit before field use.",
              "SG90 tilt torque margin is intentionally low so the workflow surfaces a mechanical finding."
            ],
            "explicit_exclusions": [
              "No EMC certification.",
              "No environmental qualification.",
              "No production enclosure finish."
            ]
          }
        },
        "mounts": [
          {"x_mm": 6, "y_mm": 6, "d_mm": 2.2},
          {"x_mm": 74, "y_mm": 44, "d_mm": 2.2}
