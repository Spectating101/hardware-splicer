            {"ref": "J3", "type": "connector", "part": "1x04 servo header"},
            {"ref": "J4", "type": "connector", "part": "JST-XH 2-pin"}
          ],
          "power": {
            "sources": [
              {
                "name": "USB VBUS",
                "voltage_v": 5.0,
                "max_current_a": 0.5,
                "notes": "Logic and USB-UART input."
              },
              {
                "name": "External servo rail",
                "voltage_v": 5.0,
                "max_current_a": 1.5,
                "notes": "Feeds J3 servo power only."
