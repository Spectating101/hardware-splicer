          ],
          "connectors": [
            {
              "name": "J1 USB",
              "type": "USB micro-B",
              "external": true,
              "hotplug": true,
              "notes": "Programming and logic input."
            },
            {
              "name": "J3 servo header",
              "type": "1x04 pin header",
              "external": true,
              "hotplug": false,
              "notes": "GND, external 5V servo rail, pan PWM, tilt PWM."
            },
            {
              "name": "J4 servo 5V input",
              "type": "JST-XH 2-pin",
