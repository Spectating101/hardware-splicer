# Hardware-Splicer local secrets (copy to .env.local; never commit .env.local)

# Simulation / bench testing only — relaxes salvage hazard holds, robotics sim blockers,
# production release gates, fab prototype cap, and auto-applies vision notes.
# Leave unset or 0 for normal safety behavior.
# HARDWARE_SPLICER_TESTING_MODE=1

# Qwen vision (Singapore intl endpoint, free-tier friendly)
DASHSCOPE_API_KEY=
QWEN_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
HARDWARE_SPLICER_VISION_PROVIDER=qwen
HARDWARE_SPLICER_VISION_MODEL=qwen3-vl-flash-2026-01-22
HARDWARE_SPLICER_VISION_LEDGER=data/vision/hardware-splicer-vision-usage.json

# Text LLM — cache, ledger, provider chain (Qwen HTTP + agy CLI fallback)
HARDWARE_SPLICER_LLM_PROVIDER=qwen_then_agy
HARDWARE_SPLICER_LLM_CACHE=1
HARDWARE_SPLICER_LLM_CACHE_DIR=.cache/hardware-splicer/llm-responses
HARDWARE_SPLICER_TEXT_LEDGER=data/llm/hardware-splicer-text-usage.json
# Offline attachment inventory (filename/meta/OCR before vision API)
HARDWARE_SPLICER_OFFLINE_OCR=1
# HARDWARE_SPLICER_LLM_CACHE_BYPASS=1
# HARDWARE_SPLICER_AGY_MODEL=gemini-2.5-flash
# HARDWARE_SPLICER_AGY_TIMEOUT_S=600
# HARDWARE_SPLICER_AGY_DISABLED=1
#
# Provider modes: qwen | agy | qwen_then_agy (default) | agy_then_qwen
#
# Each Qwen model has its own ~1M free pool (Singapore). Per-stage profiles spread
# load across families (Flash for picks, Coder for netlist JSON, Plus for workshop review).
# Full guide: ../../../docs/DASHSCOPE_MODEL_GUIDE.md (llm_automation repo)
#
# Global fallback (when a stage pool exhausts, rotation continues through these):
# HARDWARE_SPLICER_QWEN_TEXT_MODEL=qwen3.5-flash
# HARDWARE_SPLICER_QWEN_TEXT_MODEL_ROTATION=qwen3.5-flash,qwen-flash,qwen3-coder-flash,deepseek-v3.2,qwen-plus-2025-07-28,qwen-turbo
# HARDWARE_SPLICER_QWEN_LOW_QUOTA_MODELS=qwen-turbo
#
# Per-stage overrides (optional — defaults are tuned in qwen_model_policy.py):
# HARDWARE_SPLICER_QWEN_SALVAGE_MODEL=qwen3.5-flash
# HARDWARE_SPLICER_QWEN_BUILD_PICK_MODEL=qwen3.5-flash
# HARDWARE_SPLICER_QWEN_MODULE_PICK_MODEL=qwen3.5-flash
# HARDWARE_SPLICER_QWEN_COMPOSE_MODEL=qwen3-coder-flash
# HARDWARE_SPLICER_QWEN_COMPOSE_RETRY_MODEL=qwen3-coder-flash
# HARDWARE_SPLICER_QWEN_WORKSHOP_MODEL=qwen3.5-plus
# HARDWARE_SPLICER_QWEN_NARRATIVE_MODEL=qwen-flash
#
# Vision — board scene vs OCR vs escalation (low-confidence retry):
# HARDWARE_SPLICER_VISION_STAGE=board
# HARDWARE_SPLICER_QWEN_VISION_BOARD_MODEL=qwen3-vl-flash-2026-01-22
# HARDWARE_SPLICER_QWEN_VISION_OCR_MODEL=qwen-vl-ocr-2025-11-20
# HARDWARE_SPLICER_QWEN_VISION_ESCALATION_MODEL=qwen3-vl-30b-a3b-thinking
# HARDWARE_SPLICER_VISION_ESCALATE_ON_LOW_CONFIDENCE=1
# HARDWARE_SPLICER_QWEN_VISION_MODEL_ROTATION=qwen3-vl-flash-2026-01-22,qwen-vl-ocr-2025-11-20,qwen3-vl-flash
# HARDWARE_SPLICER_QWEN_LOW_QUOTA_VISION_MODELS=qwen3-vl-flash

# Optional Gemini fallback
# GEMINI_API_KEY=
# HARDWARE_SPLICER_VISION_PROVIDER=gemini
