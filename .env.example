# Hardware-Splicer local secrets (copy to .env.local; never commit .env.local)

# Simulation / bench testing only — relaxes salvage hazard holds, robotics sim blockers,
# production release gates, fab prototype cap, and auto-applies vision notes.
# Leave unset or 0 for normal safety behavior.
# HARDWARE_SPLICER_TESTING_MODE=1

# Qwen vision (Singapore intl endpoint, free-tier friendly)
DASHSCOPE_API_KEY=
QWEN_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
HARDWARE_SPLICER_VISION_PROVIDER=qwen
HARDWARE_SPLICER_VISION_MODEL=qwen3-vl-flash
HARDWARE_SPLICER_VISION_LEDGER=data/vision/hardware-splicer-vision-usage.json

# Optional Gemini fallback
# GEMINI_API_KEY=
# HARDWARE_SPLICER_VISION_PROVIDER=gemini
