# Splice Agent — nginx reverse proxy (example)
#
# Install: sudo cp splice-agent.conf.example /etc/nginx/sites-available/splice-agent
#          sudo ln -s /etc/nginx/sites-available/splice-agent /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
#
# Replace:
#   splice.example.lan  — your LAN hostname
#   /etc/ssl/splice/    — your TLS cert paths
#   CHANGE_ME_API_KEY   — shared secret for clients

limit_req_zone $binary_remote_addr zone=splice_limit:10m rate=10r/s;

server {
    listen 443 ssl http2;
    server_name splice.example.lan;

    ssl_certificate     /etc/ssl/splice/fullchain.pem;
    ssl_certificate_key /etc/ssl/splice/privkey.pem;

    # Optional: restrict to lab subnet
    # allow 192.168.1.0/24;
    # deny all;

    location / {
        limit_req zone=splice_limit burst=20 nodelay;

        if ($http_x_api_key != "CHANGE_ME_API_KEY") {
            return 401;
        }

        proxy_pass http://127.0.0.1:8787;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # Long-running splice builds
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }
}

server {
    listen 80;
    server_name splice.example.lan;
    return 301 https://$host$request_uri;
}
