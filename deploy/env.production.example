# Circuit.AI Production Environment Configuration

# API Configuration
API_VERSION=1.0.0
HOST=0.0.0.0
PORT=8000
DEBUG=false

# Database Configuration
DATABASE_URL=postgresql://circuit_ai:${POSTGRES_PASSWORD}@postgres:5432/circuit_ai
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Stripe Configuration
STRIPE_SECRET_KEY=${STRIPE_SECRET_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}
STRIPE_PRO_PRICE_ID=${STRIPE_PRO_PRICE_ID}
STRIPE_ENTERPRISE_PRICE_ID=${STRIPE_ENTERPRISE_PRICE_ID}

# Security
SECRET_KEY=${SECRET_KEY}
JWT_SECRET=${JWT_SECRET}
CORS_ORIGINS=https://circuit.ai,https://console.circuit.ai,https://api.circuit.ai

# Monitoring
PROMETHEUS_ENABLED=true
GRAFANA_ENABLED=true
LOG_LEVEL=INFO
LOG_FORMAT=json

# File Storage
UPLOAD_DIR=/app/data/uploads
ANNOTATED_DIR=/app/data/annotated
MAX_FILE_SIZE=10485760  # 10MB

# AI/ML Configuration
YOLO_MODEL_PATH=/app/models/yolov8n.pt
ENABLE_OCR=false
DEFAULT_BACKEND=enhanced

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_STORAGE=redis

# External Services
COHERE_API_KEY=${COHERE_API_KEY}
MISTRAL_API_KEY=${MISTRAL_API_KEY}
CEREBRAS_API_KEY=${CEREBRAS_API_KEY}

# Frontend Configuration
NEXT_PUBLIC_API_BASE_URL=https://api.circuit.ai
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=${STRIPE_PUBLISHABLE_KEY}

# Deployment
ENVIRONMENT=production
SENTRY_DSN=${SENTRY_DSN}
